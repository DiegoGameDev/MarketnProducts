<div class="bg-dark text-white p-3" style="width:250px; min-height:100vh;">
    <h4 class="mb-4">Reviewer</h4>

    <ul class="nav nav-pills flex-column">
        <li class="nav-item mb-2">
            <a class="nav-link text-white @(ViewBag.Active == "Pendentes" ? "bg-primary" : "")"
               asp-controller="Reviewers"
               asp-action="PendingList">
                ⏳ Pendentes
            </a>
        </li>

        <li class="nav-item mb-2">
            <a class="nav-link text-white @(ViewBag.Active == "Aprovados" ? "bg-success" : "")"
               asp-controller="Reviewers"
               asp-action="ApprovedList">
                ✅ Aprovados
            </a>
        </li>

        <li class="nav-item mb-2">
            <a class="nav-link text-white @(ViewBag.Active == "Rejeitados" ? "bg-danger" : "")"
               asp-controller="Reviewers"
               asp-action="RejectedList">
                ❌ Rejeitados
            </a>
        </li>
    </ul>
</div>