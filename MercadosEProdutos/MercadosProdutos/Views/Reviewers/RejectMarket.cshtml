@model DBModel.MarketRequestCreation

<h2>Rejeitar Mercado</h2>

<div class="card p-3 mb-3">
    <h4>@Model.Market.marketName</h4>
    <p><strong>ID:</strong> @Model.ID</p>
    <p><strong>Criado por:</strong> @Model.Market.marketLocal</p>
</div>

<form asp-action="ConfirmReject" method="post">
    <input type="hidden" name="MarketId" value="@Model.MarketId" />
    <input type="hidden" name="RejectionReason" value="@Model.RejectionReason" />

    <div class="mb-3">
        <label class="form-label">Motivo da rejeição</label>
        <textarea asp-for="RejectionReason" name="reason" class="form-control" rows="4" required
                  placeholder="Explique por que este mercado foi rejeitado..."></textarea>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-danger">
            Rejeitar
        </button>

        <a asp-action="Pendentes" class="btn btn-secondary">
            Cancelar
        </a>
    </div>
</form>