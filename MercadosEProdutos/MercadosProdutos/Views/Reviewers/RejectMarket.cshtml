@model DBModel.MarketRequestCreation

<h2>Rejeitar Mercado</h2>

<div class="card p-3 mb-3">
    <h4>@Model.Market.marketName</h4>
    <p><strong>Localização:</strong> @Model.Market.marketLocal</p>
</div>

<form asp-action="ConfirmReject" method="post">
    <input type="hidden" name="Id" value="@Model.ID" />
    <input type="hidden" name="MarketId" value="@Model.MarketId" />

    <select aria-readonly="true" asp-for="Status">
        <option value="2">Reject</option>
    </select>

    <div class="mb-3">
        <label class="form-label">Motivo da rejeição</label>
        <input type="text" aria-rowcount="4" asp-for="RejectionReason" class="form-control">
        </input>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-danger">
            Rejeitar
        </button>

        <a asp-action="Pendentes" class="btn btn-secondary">
            Cancelar
        </a>
    </div>
</form>