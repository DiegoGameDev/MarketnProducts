<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MercadosProdutos</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MercadosProdutos.styles.css" asp-append-version="true" />
</head>
<body>
    <body>

    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom mb-3">
        <div class="container-fluid">
            <a class="navbar-brand" asp-controller="MarketPlace" asp-action="Index">MercadosProdutos</a>

            <div class="collapse navbar-collapse">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="MyMarket" asp-action="Index">Meu Mercado</a>
                    </li>

                    @if (User.IsInRole("Reviewer") || User.IsInRole("Admin"))
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Reviewers" asp-action="Index">Área de Análise</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <!-- CORPO -->
    <div class="d-flex">

        <!-- SIDEBAR (component) -->
        @await Component.InvokeAsync("Reviewer")

        <!-- CONTEÚDO -->
        <div class="flex-grow-1 p-4">
            @RenderBody()
        </div>

    </div>

</body>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - MercadosProdutos - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
