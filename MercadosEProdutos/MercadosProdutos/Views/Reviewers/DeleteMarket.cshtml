@using Enums
@model DBModel.MarketRequestCreation

<h2>Rejeitar Mercado</h2>

<div class="card p-3 mb-3">
    <h4>@Model.Market.marketName</h4>
    <p><strong>Localização:</strong> @Model.Market.marketLocal</p>
</div>

<form asp-action="ConfirmDelete" method="post">
    <input type="hidden" asp-for="MarketId"/>
    <input type="hidden" asp-for="RejectionReason"/>
    <input type="hidden" asp-for="Status"/>

    <div class="mb-3">
        <label class="form-label">Motivo da remoção</label>
        <input type="text" asp-for="RejectionReason" class="form-control"/>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-danger">
            Deletar
        </button>

        <a asp-action="PendingList" class="btn btn-secondary">
            Cancelar
        </a>
    </div>
</form>