@{
    Layout = "LayoutReviewer.cshtml";
}

@{
    ViewData["Title"] = "Painel de Revisão";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"]</title>

    <!-- Bootstrap CDN -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body>

<div class="d-flex">

    <!-- SIDEBAR -->
    

    <!-- CONTEÚDO -->
    <div class="flex-grow-1 p-4">

        <h2>@ViewData["Title"]</h2>

        <hr />

        @if (Model != null)
        {
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Nome</th>
                        <th>Local</th>
                        <th>Status</th>
                        <th>Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Name</td>
                            <td>@item.Location</td>
                            <td>@item.Status</td>
                            <td>
                                <a asp-action="Aprovar" asp-route-id="@item.Id" class="btn btn-success btn-sm">Aprovar</a>
                                <a asp-action="Rejeitar" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Rejeitar</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }

    </div>

</div>

</body>
</html>